<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="256.0" prefWidth="387.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dba.nvlcheck.NVLCheck">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" styleClass="root" stylesheets="@../../../css/style.css">
        <Label fx:id="labelJDK" layoutX="68.0" layoutY="552.0" text="JavaSDK" />
        <Label fx:id="labelJavaFX" layoutX="72.0" layoutY="569.0" text="JavaFX" />

        <Label fx:id="labelSourceFile" layoutX="42.0" layoutY="78.0" prefHeight="20.0" prefWidth="700.0" />

        <Label fx:id="labelTargetFile" layoutX="42.0" layoutY="118.0" prefHeight="20.0" prefWidth="700.0" />
        <Label fx:id="labelResult" layoutX="169.0" layoutY="292.0" prefHeight="17.0" prefWidth="352.0" />
        <TableView fx:id="tableDiff" layoutX="34.0" layoutY="214.0" prefHeight="330.0" prefWidth="732.0">
            <columns>
                <TableColumn fx:id="itemCol" prefWidth="116.0" text="Item" />
                <TableColumn fx:id="quantityCol" prefWidth="94.0" text="Quantity" />
                <TableColumn fx:id="skuCol" prefWidth="330.0" text="SKU" />
            </columns>
        </TableView>
        <Button fx:id="buttonSource" layoutX="43.0" layoutY="32.0" mnemonicParsing="false" onAction="#handleOpenSourceFile" stylesheets="@../../../css/style.css" text="Select Source" />
        <Button fx:id="buttonCompare" layoutX="521.0" layoutY="36.0" mnemonicParsing="false" onAction="#handleCompare" prefHeight="30.0" prefWidth="87.0" stylesheets="@../../../css/style.css" text="Compare" />
        <Button fx:id="buttonTarget" layoutX="312.0" layoutY="36.0" mnemonicParsing="false" onAction="#handleOpenTargetFile" stylesheets="@../../../css/style.css" text="Select Target" />
        <Button fx:id="buttonQuit" layoutX="682.0" layoutY="36.0" mnemonicParsing="false" onAction="#handleQuit" stylesheets="@../../../css/style.css" text="Quit" />
    </AnchorPane>
</VBox>
